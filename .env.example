# ─── Copy this file to .env and fill in your real values ───────────────────
# Hostinger will set PORT automatically — leave it blank
PORT=3000

# Your real domain — e.g. https://portal.fastprofessional.com
BASE_URL=https://portal.fastprofessional.com

# Secret keys — change these to long random strings before going live!
JWT_SECRET=change-this-to-a-long-random-secret-string-min-32-chars
ENCRYPTION_KEY=change-this-32-char-encryption-key!!

# Admin email for notifications
ADMIN_EMAIL=wajahat@fastprofessional.com
